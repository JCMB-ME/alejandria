# =============================================================================
# Alejandría configuration
# Copy to .env and adjust values
# =============================================================================
#
# ⚠️  CRITICAL — the app refuses to start with these defaults set. ⚠️
# ----------------------------------------------------------------
# Two values MUST be set before the app will boot. The defaults below
# are placeholders to make it obvious they are unsafe; the app's startup
# validator rejects them.
#
#   • ALEJANDRIA_SECRET_KEY  — signs every JWT session cookie.
#     Generate:  python -c "import secrets; print(secrets.token_urlsafe(64))"
#
#   • ALEJANDRIA_ADMIN_PASSWORD  — created on first startup only.
#     Use 8+ chars; you can change it later from the Settings UI.
#
# Escape hatch for local dev / tests ONLY:
#   ALEJANDRIA_ALLOW_INSECURE_DEFAULTS=true
# The app will boot but log a warning on every request. Never set this
# in any environment that is reachable beyond localhost.
# ----------------------------------------------------------------

# ----- Server -----
ALEJANDRIA_HOST=0.0.0.0
ALEJANDRIA_PORT=8080
ALEJANDRIA_BASE_URL=http://localhost:8080

# ----- Security -----
ALEJANDRIA_SECRET_KEY=<CHANGE-ME: run `python -c "import secrets; print(secrets.token_urlsafe(64))"`>
# Set to true ONLY for local dev / tests; never in production.
ALEJANDRIA_ALLOW_INSECURE_DEFAULTS=false
# Whether the session cookie requires HTTPS. Default true in production.
# Set to false for local HTTP dev only.
ALEJANDRIA_COOKIE_SECURE=true
# Whether OPDS requires authentication. Default true. Set false ONLY
# for trusted LAN deployments (e.g. KOReader on the same network).
ALEJANDRIA_OPDS_REQUIRE_AUTH=true

# Session lifetime in seconds (default 30 days)
ALEJANDRIA_SESSION_LIFETIME=2592000

# ----- Initial admin (only used on first startup) -----
# Note: changing these AFTER first startup has no effect. The admin
# account is created on first run; afterwards, manage users from the
# Settings UI.
ALEJANDRIA_ADMIN_USERNAME=admin
ALEJANDRIA_ADMIN_PASSWORD=<CHANGE-ME: a strong password, 8+ chars>
ALEJANDRIA_ADMIN_EMAIL=admin@example.com

# ----- Library paths (inside container) -----
ALEJANDRIA_LIBRARY_PATH=/library
ALEJANDRIA_CONFIG_PATH=/config
ALEJANDRIA_CACHES_PATH=/config/caches

# ----- PUID/PGID for homelab (linuxserver.io convention) -----
PUID=1000
PGID=1000
TZ=UTC

# ----- Calibre integration -----
# Set to "true" to enable Calibre CLI for format conversion and metadata
# Requires Calibre to be installed in the container (default image includes it)
ALEJANDRIA_ENABLE_CALIBRE=true
# Path to calibredb binary (auto-detected if empty)
CALIBRE_BIN=

# ----- Conversion -----
# Maximum concurrent ebook-convert subprocesses. Default 2. Increase if you
# have many simultaneous readers requesting MOBI/DJVU conversions.
ALEJANDRIA_CONVERT_MAX_CONCURRENT=2

# ----- SMTP (for Send-to-Kindle and notifications) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ----- Kindle delivery -----
# Default Kindle email recipients (comma-separated)
KINDLE_EMAILS=

# ----- OIDC / SSO (optional) -----
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# ----- Database -----
# Path inside container
ALEJANDRIA_DB_PATH=/config/alejandria.db

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Web scraper -----
ALEJANDRIA_SCRAPER_ENABLED=true
ALEJANDRIA_SCRAPER_OUTPUT_DIR=/config/scrapes
ALEJANDRIA_SCRAPER_MAX_CONCURRENT_JOBS=2
ALEJANDRIA_SCRAPER_MAX_PAGES_PER_JOB=2000
ALEJANDRIA_SCRAPER_DEFAULT_DELAY_MS=500
ALEJANDRIA_SCRAPER_MAX_TOTAL_SIZE_MB=500
ALEJANDRIA_SCRAPER_BROWSER_HEADLESS=true
ALEJANDRIA_SCRAPER_ADAPTERS_FILE=/config/site-adapters.yaml
ALEJANDRIA_SCRAPER_PROXY=
ALEJANDRIA_SCRAPER_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

